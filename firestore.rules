rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3 Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { 
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == 'arya4186@gmail.com'); 
    }
    function isUserEmail(email) { return isSignedIn() && request.auth.token.email == email; }
    function isAdmin() { 
      return isUserEmail('arya4186@gmail.com') || isUserEmail('arya.taskmanagement@gmail.com') || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 1. Business Validation
    function isValidBusiness(data) {
      return data.keys().hasAll(['id', 'name']) &&
             data.id is string && data.id.size() <= 64 &&
             data.name is string && data.name.size() <= 256;
    }

    match /businesses/{businessId} {
      allow read: if isSignedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Team Member Validation
    match /teamMembers/{memberId} {
      allow read: if isVerified();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 3. Internal Admin Task (The AdminTask[] array)
    match /internalAdminTasks/{taskId} {
      allow read: if isSignedIn();
      allow create, update: if isVerified();
      allow delete: if isAdmin();
    }

    // 4. Business Action Items (Record<string, tasks[]>)
    match /businessActionItems/{bizId} {
      allow read: if isSignedIn();
      allow create, update: if isVerified();
      allow delete: if isAdmin();
    }

    // 4.1 Admin Action Items (Team Notes for Admin)
    match /adminActionItems/{bizId} {
      allow read: if isSignedIn();
      allow create, update: if isVerified();
      allow delete: if isAdmin();
    }

    // 5. Extra Work Validation
    match /extraWorks/{workId} {
      allow read: if isSignedIn();
      allow create, update: if isVerified();
      allow delete: if isAdmin();
    }

    // 6. Settings & Config
    match /settings/config {
       allow read: if isSignedIn();
       allow create, update: if isAdmin();
    }
    
    match /config/{configId} {
      allow read: if isSignedIn(); 
      allow create, update: if isAdmin();
    }
    
    // Explicit heartbeat path
    match /config/status {
      allow read: if true;
    }

    // 6.1 App Versioning & System Config
    match /appConfig/system {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6.2 Health Check & Heartbeat
    match /_health_/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /taskData/{taskId} {
       allow read: if isSignedIn();
       allow create, update, delete: if isVerified();
    }

    match /customTaskDescriptions/{taskId} {
       allow read: if isSignedIn();
       allow create, update, delete: if isVerified();
    }

    match /workSessions/{sessionId} {
       allow read: if isSignedIn();
       allow create, update, delete: if isVerified();
    }

    match /logs/{logId} {
       allow read, write, delete: if isSignedIn();
    }
    
    // Auth for admin bootstrap
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
